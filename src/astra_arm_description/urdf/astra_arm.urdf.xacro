<?xml version="1.0"?>

<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="astra_arm">

  <!-- ========================= -->
  <!-- Materials -->
  <!-- ========================= -->

  <material name="yellow">
    <color rgba="0.95 0.80 0.10 1.0"/>
  </material>

  <material name="black">
    <color rgba="0.15 0.15 0.15 1.0"/>
  </material>

  <!-- ========================= -->
  <!-- Base -->
  <!-- ========================= -->

  <link name="base_link">

    <visual>
      <geometry>
        <cylinder radius="0.09" length="0.06"/>
      </geometry>
      <material name="black"/>
    </visual>

    <collision>
      <geometry>
        <cylinder radius="0.09" length="0.06"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="2.0"/>
      <origin xyz="0 0 0"/>
      <inertia
        ixx="0.02"
        iyy="0.02"
        izz="0.02"
        ixy="0"
        ixz="0"
        iyz="0"/>
    </inertial>

  </link>

  <!-- ========================= -->
  <!-- Shoulder -->
  <!-- ========================= -->

  <link name="shoulder_link">

    <visual>

      <origin xyz="0 0 0.06"/>

      <geometry>
        <box size="0.08 0.08 0.12"/>
      </geometry>

      <material name="yellow"/>

    </visual>

  </link>

  <!-- ========================= -->
  <!-- Shoulder Joint -->
  <!-- ========================= -->

  <joint name="shoulder_joint" type="revolute">

    <parent link="base_link"/>

    <child link="shoulder_link"/>

    <origin xyz="0 0 0.03" rpy="0 0 0"/>

    <axis xyz="0 0 1"/>

    <limit
      lower="-3.14"
      upper="3.14"
      effort="20"
      velocity="2"/>

  </joint>

</robot>