<?xml version="1.0"?>

<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="astra_arm">

  <!-- ========================= -->
  <!-- Materials -->
  <!-- ========================= -->

  <material name="black">
    <color rgba="0.15 0.15 0.15 1.0"/>
  </material>

  <material name="yellow">
    <color rgba="0.95 0.80 0.10 1.0"/>
  </material>

  <material name="silver">
    <color rgba="0.75 0.75 0.75 1.0"/>
  </material>

  <!-- ========================= -->
  <!-- Base -->
  <!-- ========================= -->

  <link name="base_link">
    <visual>
      <geometry>
        <cylinder radius="0.09" length="0.06"/>
      </geometry>
      <material name="black"/>
    </visual>

    <collision>
      <geometry>
        <cylinder radius="0.09" length="0.06"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="2.0"/>
      <origin xyz="0 0 0"/>
      <inertia
        ixx="0.02"
        iyy="0.02"
        izz="0.02"
        ixy="0"
        ixz="0"
        iyz="0"/>
    </inertial>
  </link>

  <!-- ========================= -->
  <!-- Shoulder -->
  <!-- ========================= -->

  <link name="shoulder_link">
    <visual>
      <origin xyz="0 0 0.06"/>
      <geometry>
        <box size="0.08 0.08 0.12"/>
      </geometry>
      <material name="yellow"/>
    </visual>
  </link>

  <joint name="shoulder_joint" type="revolute">
    <parent link="base_link"/>
    <child link="shoulder_link"/>
    <origin xyz="0 0 0.03"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="20" velocity="2"/>
  </joint>

  <!-- ========================= -->
  <!-- Upper Arm -->
  <!-- ========================= -->

  <link name="upper_arm_link">
    <visual>
      <origin xyz="0 0 0.12"/>
      <geometry>
        <box size="0.05 0.05 0.24"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <joint name="elbow_joint" type="revolute">
    <parent link="shoulder_link"/>
    <child link="upper_arm_link"/>
    <origin xyz="0 0 0.12"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="20" velocity="2"/>
  </joint>

  <!-- ========================= -->
  <!-- Forearm -->
  <!-- ========================= -->

  <link name="forearm_link">
    <visual>
      <origin xyz="0 0 0.11"/>
      <geometry>
        <box size="0.04 0.04 0.22"/>
      </geometry>
      <material name="yellow"/>
    </visual>
  </link>

  <joint name="wrist_joint" type="revolute">
    <parent link="upper_arm_link"/>
    <child link="forearm_link"/>
    <origin xyz="0 0 0.24"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="15" velocity="2"/>
  </joint>

  <!-- ========================= -->
  <!-- Wrist -->
  <!-- ========================= -->

  <link name="wrist_link">
    <visual>
      <origin xyz="0 0 0.04"/>
      <geometry>
        <cylinder radius="0.025" length="0.08"/>
      </geometry>
      <material name="silver"/>
    </visual>
  </link>

  <joint name="wrist_roll_joint" type="revolute">
    <parent link="forearm_link"/>
    <child link="wrist_link"/>
    <origin xyz="0 0 0.22"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="10" velocity="2"/>
  </joint>

  <!-- ========================= -->
  <!-- Gripper -->
  <!-- ========================= -->

  <link name="gripper_link">
    <visual>
      <origin xyz="0 0 0.05"/>
      <geometry>
        <box size="0.06 0.04 0.10"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <joint name="gripper_joint" type="fixed">
    <parent link="wrist_link"/>
    <child link="gripper_link"/>
    <origin xyz="0 0 0.08"/>
  </joint>

</robot>